# Development environment template.
# Copy to .env for local overrides. Do not commit real secrets.

# ---------------------------------------------------------------------------
# Shared service discovery
# ---------------------------------------------------------------------------
CONFIG_SERVER_URL=http://config-server:8000
STALE_AFTER_SECONDS=30

# ---------------------------------------------------------------------------
# API Gateway / Frontend
# ---------------------------------------------------------------------------
# Use http://api-gateway:8000 when frontend runs in Docker.
# Use http://localhost:8000 when running frontend locally on the host.
API_GATEWAY_URL=http://api-gateway:8000

# ---------------------------------------------------------------------------
# Auth Service
# ---------------------------------------------------------------------------
# Use a long random value outside local development.
JWT_SECRET=change-me-in-real-environments
TOKEN_TTL_SECONDS=3600
REDIS_URL=redis://redis:6379/0

# Auth service-local DATABASE_URL:
# DATABASE_URL=postgresql://auth_user:auth_pass@auth-db:5432/auth_db

# Auth PostgreSQL container defaults:
AUTH_POSTGRES_USER=auth_user
AUTH_POSTGRES_PASSWORD=auth_pass
AUTH_POSTGRES_DB=auth_db

# ---------------------------------------------------------------------------
# Catalog Service
# ---------------------------------------------------------------------------
MONGO_URL=mongodb://mongo1:27017,mongo2:27017,mongo3:27017/catalog_db?replicaSet=rs0

# ---------------------------------------------------------------------------
# Reviews Service / Outbox Publisher
# ---------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=review.created
OUTBOX_POLL_INTERVAL_SECONDS=2

# Reviews service-local DATABASE_URL:
# DATABASE_URL=postgresql://reviews_user:reviews_pass@reviews-db:5432/reviews_db

# Reviews PostgreSQL container defaults:
REVIEWS_POSTGRES_USER=reviews_user
REVIEWS_POSTGRES_PASSWORD=reviews_pass
REVIEWS_POSTGRES_DB=reviews_db

# ---------------------------------------------------------------------------
# Feed API / Feed Consumer
# ---------------------------------------------------------------------------
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123
NEO4J_AUTH=neo4j/password123

# ---------------------------------------------------------------------------
# Instance registration
# ---------------------------------------------------------------------------
# Docker Compose sets INSTANCE_NAME and PUBLIC_URL per container.
# Examples for local single-service runs:
# INSTANCE_NAME=auth-service-local
# PUBLIC_URL=http://localhost:8000
